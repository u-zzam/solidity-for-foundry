{
  "comments": {
    "lineComment": "//",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'", "close": "'", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "wordPattern": "[A-Za-z_$][A-Za-z0-9_$]*",
  "onEnterRules": [
    {
      "beforeText": "^\\s*/\\*\\*(?!/)([^\\*]|\\*(?!/))*$",
      "afterText": "^\\s*\\*/$",
      "action": { "indent": "indentOutdent", "appendText": " * " }
    },
    {
      "beforeText": "^\\s*/\\*\\*(?!/)([^\\*]|\\*(?!/))*$",
      "action": { "indent": "none", "appendText": " * " }
    },
    {
      "beforeText": "^(\\t|[ ])*[ ]\\*([ ]([^\\*]|\\*(?!/))*)?$",
      "previousLineText": "(?=^(\\s*(/\\*\\*|\\*)).*)(?=(?!(\\s*\\*/)))",
      "action": { "indent": "none", "appendText": "* " }
    },
    {
      "beforeText": "^(\\t|[ ])*[ ]\\*/\\s*$",
      "action": { "indent": "none", "removeText": 1 }
    },
    {
      "beforeText": "^(\\t|[ ])*[ ]\\*[^/]*\\*/\\s*$",
      "action": { "indent": "none", "removeText": 1 }
    }
  ]
}
