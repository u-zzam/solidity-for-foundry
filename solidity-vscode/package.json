{
  "name": "solidity-for-foundry",
  "displayName": "Solidity for Foundry",
  "description": "The Solidity language server for the modern, Foundry-native stack: diagnostics, formatting, and navigation on your project's exact solc version.",
  "version": "0.3.0",
  "license": "MIT",
  "publisher": "u-zzam",
  "repository": { "type": "git", "url": "https://github.com/u-zzam/solidity-for-foundry" },
  "bugs": { "url": "https://github.com/u-zzam/solidity-for-foundry/issues" },
  "engines": { "vscode": "^1.75.0" },
  "categories": ["Programming Languages"],
  "keywords": ["ethereum", "forge", "foundry", "solidity", "smart contracts"],
  "activationEvents": ["onLanguage:solidity"],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "solidity",
        "aliases": ["Solidity"],
        "extensions": [".sol"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "solidity",
        "scopeName": "source.solidity",
        "path": "./syntaxes/solidity.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "solidity.restartServer",
        "title": "Restart Server",
        "category": "Solidity"
      }
    ],
    "configuration": {
      "title": "Solidity for Foundry",
      "properties": {
        "solidity.serverPath": {
          "type": "string",
          "default": "",
          "description": "Path to the solidity-for-foundry-lsp server binary. Leave empty to download the release binary matching this extension's version automatically; set to a path (or a name on PATH, e.g. \"solidity-for-foundry-lsp\") to use your own build."
        },
        "solidity.trace.server": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Trace the communication between VS Code and the Solidity language server, shown in the server's output channel."
        },
        "solidity.experimental.inlayHints": {
          "type": "boolean",
          "default": true,
          "description": "(Experimental) Show call-site parameter-name inlay hints in Solidity files. Takes effect after the server restarts."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.4.0"
  }
}
